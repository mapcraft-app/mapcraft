{
  "name": "mapcraft",
  "description": "Mapcraft is a software that increases the possibilities of mapmakers without any complex installation",
  "homepage": "https://mapcraft.app",
  "license": "GPL-3.0",
  "author": {
    "name": "Clément Bertrand",
    "email": "hello@mapcraft.app"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/cbertran/mapcraft.git"
  },
  "productName": "mapcraft",
  "version": "0.6.0-alpha",
  "keywords": [
    "mapcraft",
    "minecraft"
  ],
  "main": "src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "debug": "electron --trace-warnings .",
    "package": "electron-forge package",
    "publish": "electron-forge publish",
    "pack": "sh ./build/install_sql.sh && electron-builder -mwl --x64 --dir ",
    "dist": "sh ./build/install_sql.sh && electron-builder -wl --x64",
    "distMac": "yarn add --dev dmg-license && sh ./build/install_sql.sh && electron-builder -m --x64",
    "postinstall": "electron-builder install-app-deps",
    "lint": "echo \"No linting configured\""
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "src/dist/img/icon/icon"
      }
    }
  },
  "build": {
    "appId": "com.electron.mapcraft",
    "productName": "mapcraft",
    "copyright": "Copyright (C) 2020 - 2021, Clément Bertrand",
    "asar": true,
    "npmRebuild": false,
   
    "directories": {
      "buildResources": "build",
      "output": "out"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "src/dist/img/icon/icon.ico",
      "artifactName": "${productName}_${os}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "displayLanguageSelector": true,
      "license": "LICENSE",
      "installerLanguages": [
        "en_US",
        "fr_FR"
      ],
      "language": 1033
    },
    "mac": {
      "category": "public.app-category.productivity",
      "type": "distribution",
      "icon": "src/dist/img/icon/icon.icns",
      "artifactName": "${productName}_${os}.${ext}",
      "target": [
      	"dmg",
        "zip"
      ]
    },
    "dmg": {
      "backgroundColor": "#181a1b",
      "iconSize": 75,
      "window": {
        "width": 544,
        "height": 408
      },
      "contents": [
        {
          "x": 110,
          "y": 150
        },
        {
          "x": 240,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "src/dist/img/icon/icon.png",
      "artifactName": "${productName}_${os}.${ext}",
      "target": [
        "AppImage",
        "zip"
      ],
      "synopsis": "Mapcraft is a software that increases the possibilities of mapmakers without any complex installation",
      "category": "Development"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.5",
    "axios": "^0.23.0",
    "better-sqlite3": "^7.4.0",
    "bezier-easing": "^2.1.0",
    "electron-squirrel-startup": "^1.0.0",
    "jsonabc": "^2.3.1",
    "markdown-it": "^12.0.6",
    "read-last-lines": "^1.8.0",
    "node-abi": "^3.2.0"
  },
  "resolutions": { "**/node-abi": "^3.2.0" },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.59",
    "dmg-builder": "^22.11.11",
    "electron": "15.1.2",
    "electron-builder": "^22.11.7"
  }
}
