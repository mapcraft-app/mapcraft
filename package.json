{
  "name": "mapcraft",
  "productName": "mapcraft",
  "version": "0.1.0-alpha",
  "description": "Mapcraft software",
  "main": "src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make-full": "electron-forge make --platform linux; electron-forge make --platform darwin; electron-forge make --platform win32",
    "make-linux": "electron-forge make --platform linux",
    "make-mac": "electron-forge make --platform darwin",
    "make-windows": "electron-forge make --platform win32",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [
    "mapcraft",
    "minecraft"
  ],
  "author": "Clément Bertrand",
  "license": "GPL-3.0",
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "./src/dist/img/icon/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-deb",
          "config": {
            "options": {
              "maintainer": "Clément Bertrand"
            }
          }
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {
            "options": {
              "maintainer": "Clément Bertrand"
            }
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin",
            "win32"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.5",
    "axios": "^0.21.1",
    "better-sqlite3": "^7.1.5",
    "bezier-easing": "^2.1.0",
    "electron-squirrel-startup": "^1.0.0",
    "jsonabc": "^2.3.1",
    "markdown-it": "^12.0.6",
    "read-last-lines": "^1.8.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.54",
    "@electron-forge/maker-deb": "^6.0.0-beta.54",
    "@electron-forge/maker-rpm": "^6.0.0-beta.54",
    "@electron-forge/maker-zip": "^6.0.0-beta.54",
    "electron": "12.0.5"
  }
}
