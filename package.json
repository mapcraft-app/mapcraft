{
  "name": "mapcraft-app",
  "productName": "mapcraft-app",
  "version": "0.1.0-alpha",
  "description": "My Electron application description",
  "main": "src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": ["mapcraft", "minecraft"],
  "author": "Clément Bertrand",
  "license": "GPLv3",
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "src/dist/img/icon/icon.ico"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-deb",
          "config": {
            "options": {
              "maintainer": "Clément Bertrand"
            }
          }
        },
        {
          "name": "@electron-forge/maker-rpm",
          "config": {
            "options": {
              "maintainer": "Clément Bertrand"
            }
          }
        },
        {
          "name": "@electron-forge/maker-wix",
          "config": {
            "iconUrl": "src/dist/img/icon/icon.ico",
            "loadingGif": "src/dist/img/loader.gif"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["darwin", "win32", "linux"]
        }
      ]
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.5",
    "better-sqlite3": "^7.1.5",
    "bezier-easing": "^2.1.0",
    "electron-squirrel-startup": "^1.0.0",
    "jsonabc": "^2.3.1",
    "markdown-it": "^12.0.6",
    "read-last-lines": "^1.8.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.54",
    "@electron-forge/maker-deb": "^6.0.0-beta.54",
    "@electron-forge/maker-rpm": "^6.0.0-beta.54",
    "@electron-forge/maker-squirrel": "^6.0.0-beta.54",
    "@electron-forge/maker-zip": "^6.0.0-beta.54",
    "electron": "12.0.5"
  }
}
