{
  "name": "mapcraft",
  "description": "Mapcraft is a software that increases the possibilities of mapmakers without any complex installation",
  "homepage": "https://mapcraft.app",
  "license": "GPL-3.0",
  "author": {
    "name": "Clément Bertrand",
    "email": "hello@mapcraft.app"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/cbertran/mapcraft.git"
  },
  "productName": "Mapcraft",
  "version": "0.7.6-alpha",
  "keywords": [
    "mapcraft",
    "minecraft"
  ],
  "main": "src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "debug": "electron --trace-warnings .",
    "package": "electron-forge package",
    "publish": "electron-forge publish",
    "pack": "electron-builder -mwl --x64 --dir ",
    "dist": "electron-builder -mwl --x64",
    "distMac": "electron-builder -m --x64",
    "distWindows": "electron-builder -w --x64",
    "distLinux": "electron-builder -l --x64",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint ."
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "src/dist/img/icon/icon"
      }
    }
  },
  "build": {
    "appId": "com.electron.mapcraft",
    "productName": "Mapcraft",
    "copyright": "Copyright (C) 2020 - 2022, Clément Bertrand",
    "asar": false,
    "npmRebuild": true,
    "directories": {
      "buildResources": "build",
      "output": "out"
    },
    "files": [
      "!**/{yarn.lock,.eslintrc.js,.gitlab-ci.yml,README.md}",
      "!.gitlab",
      "!build",
      "!plugins"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "src/dist/img/icon/icon.ico",
      "artifactName": "${productName}_${os}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "displayLanguageSelector": true,
      "license": "LICENSE",
      "installerLanguages": [
        "en_US",
        "fr_FR"
      ],
      "language": 1033
    },
    "mac": {
      "category": "public.app-category.productivity",
      "type": "distribution",
      "icon": "src/dist/img/icon/icon.icns",
      "artifactName": "${productName}_${os}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "background": "build/background.png",
      "iconSize": 80,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "src/dist/img/icon/icon.png",
      "artifactName": "${productName}_${os}.${ext}",
      "target": [
        "AppImage",
        "zip"
      ],
      "synopsis": "Mapcraft is a software that increases the possibilities of mapmakers without any complex installation",
      "category": "Development"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.9",
    "axios": "^0.24.0",
    "better-sqlite3": "^7.4.6",
    "bezier-easing": "^2.1.0",
    "electron-squirrel-startup": "^1.0.0",
    "jsonabc": "^2.3.1",
    "mapcraft-api": "^1.6.9",
    "markdown-it": "^12.3.0",
    "read-last-lines": "^1.8.0",
    "v8-compile-cache": "^2.3.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.0-beta.59",
    "dmg-builder": "^22.14.7",
    "electron": "^16.0.2",
    "electron-builder": "^22.14.5",
    "eslint": "^8.4.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.25.3"
  }
}
