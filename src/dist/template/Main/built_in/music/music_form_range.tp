[HTML]
<div class="uk-margin">
	<label class="uk-form-label uk-label-range" for="{ID}">{Name}</label>
	<div class="uk-form-controls uk-flex">
		<input id="{ID}" class="uk-range" type="range" value="{Value}" min="{Min}" max="{Max}" step="{Step}">
		<span id="{ID}-badge" class="uk-badge uk-badge-range"></span>
	</div>
</div>
[/HTML]

[CSS]
.uk-badge-range {
	padding: 10px;
	margin-left: 10px !important;
	border-radius: unset;
	min-width: 3.5em;
}
.uk-label-range {
	margin-top: unset;
}
[/CSS]
