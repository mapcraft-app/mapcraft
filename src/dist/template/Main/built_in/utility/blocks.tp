<html>
<div class="uk-margin uk-flex uk-flex-around search-form">
	<form id="disabled-form" class="uk-search uk-search-default search-width-40">
		<span class="uk-search-icon-flip" uk-search-icon></span>
		<input style="color: #fff" id="blocks-search" class="uk-search-input" type="search" placeholder="{Search}">
	</form>
	<a class="uk-button uk-button-default" id="block-download">
		<span uk-icon="download"></span>{Download}
	</a>
</div>
<table class="uk-table uk-table-divider uk-table-middle">
	<thead>
		<tr>
			<th class="uk-width-small">ID</th>
			<th style="text-align:center" class="uk-width-small">Icon</th>
			<th>Name</th>
		</tr>
	</thead>
	<div id="error-block-list">
		<h3>No data found</h3>
	</div>
	<tbody id="blocks-list">
	</tbody>
</table>
</html>

<style>
.search-width-40 {
	width: 40%;
}
.search-width-30 {
	width: 30%;
}
#error-block-list {
	text-align: center;
	display: none;
}
#blocks-list img {
	max-width: 75px;
}
</style>
