<html>
<tr id="{id}" uuid="{uuid}">
	<td>
		<img class="plugin-img" src="{icon}">
	</td>
	<td>{name}</td>
	<td>{version}</td>
	<td>{author}</td>
	<td>{description}</td>
	<td>
		<div class="uk-form-controls">
			<label class="uk-switch">
				<input type="checkbox">
				<div class="uk-switch-span"></div>
			</label>
		</div>
	</td>
	<td>
		<button class="uk-button uk-button-danger plugin-min-button">
			<span uk-icon="icon: trash;"></span>
		</button>
	</td>
</tr>
</html>

<style>
.plugin-img {
	max-height: 64px;
}
.plugin-min-button > span {
	min-width: 20px;
}
</style>
