    <li>
		<a href="#" lang="Plugin.Installed"></a>
	</li>
</ul>
<ul class="uk-switcher uk-margin">
    <li>
		<table id="table-builtin" class="uk-table uk-table-striped uk-table-middle table-builtin">
			<thead>
				<tr>
					<th class="uk-width-small"></th>
					<th lang="Plugin.Name"></th>
					<th lang="Plugin.Version"></th>
					<th lang="Plugin.Author"></th>
					<th lang="Plugin.Description"></th>
					<th lang="Plugin.Activate"></th>
					<th lang="Plugin.Delete"></th>
				</tr>
			</thead>
			<tbody>
			</tbody>
		</table>
	</li>
    <li>
		<div class="uk-flex uk-flex-right uk-margin-top uk-margin-bottom">
			<button id="InstallPluginArchive" class="uk-button uk-button-success">
				<span uk-icon="icon: database"></span>
				<span lang="Plugin.InstallPluginArchive"></span>
			</button>
		</div>
		<table id="table-plugin" class="uk-table uk-table-striped uk-table-middle table-plugin">
			<thead>
				<tr>
					<th class="uk-width-small"></th>
					<th lang="Plugin.Name"></th>
					<th lang="Plugin.Version"></th>
					<th lang="Plugin.Author"></th>
					<th lang="Plugin.Description"></th>
					<th lang="Plugin.Activate"></th>
					<th lang="Plugin.Delete"></th>
				</tr>
			</thead>
			<tbody></tbody>
		</table>
		<div id="loader" class="uk-flex uk-flex-center" hidden>
			<img width="64px" height="64px" src="./dist/img/loader.gif"/>
		</div>
	</li>
</ul>


</html>
