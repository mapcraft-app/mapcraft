[HTML]
<div class="uk-margin">
	<label for="{for}" class="uk-form-label" lang="{text}"></label>
	<div style="position: relative">
		<a href="#" id="{id}" class="uk-form-icon uk-form-icon-flip" uk-icon="icon: more"></a>
		<div class="uk-form-controls">
			<input style="padding-right:40px;" id="{for}" value="{path}" class="uk-input"></input>
		</div>
	</div>
</div>
[/HTML]
