<html>
<div class="uk-flex uk-flex-right uk-flex-middle uk-flex-between">
	<div class="check-margin">
		<input id="checkbox-user" class="uk-checkbox uk-margin-right" type="checkbox">
		<label for="checkbox-user" lang="SelectEveryUser"></label>
	</div>
	<button class="uk-button uk-button-primary" uk-toggle="target: #UserModalCreate" lang="CreateUser"></button>
</div>
<form name="form-user" id="form-user" class="form-user">
	<table class="uk-table uk-table-striped uk-table-middle">
		<thead>
			<tr>
				<th class="uk-table-shrink"></th>
				<th class="uk-table-shrink"></th>
				<th class="uk-table-shrink"></th>
				<th></th>
				<th class="uk-table-shrink"></th>
			</tr>
		</thead>
		<tbody id="generateTab"></tbody>
	</table>
</form>
<div class="uk-margin uk-flex uk-flex-middle uk-flex-middle uk-flex-between">
	<button id="full-delete-tab" class="uk-button uk-button-warning">
		<span uk-icon="trash"></span>
	</button>
</div>
<div id="PrintCreateUserModal">
	<div uk-modal class="uk-modal-container" id="UserModalCreate" container="#PrintCreateUserModal">
		<div class="uk-modal-dialog uk-margin-auto-vertical uk-modal-body">
			<h2 class="uk-modal-title" lang="Modal.Title"></h2>
			<button class="uk-modal-close-default" type="button" uk-close></button>
			<div id="alert-createUser-modal"></div>
			<form id="form-createUser">
				<fieldset class="uk-fieldset">
					<div class="uk-margin">
						<input id="modal-username" class="uk-input" type="text" placeholder="..."/>
					</div>
					<div class="uk-margin uk-flex uk-flex-right">
						<button type="submit" class="uk-button uk-button-primary" lang="Modal.Submit"></button>
					</div>
				</fieldset>
			</form>
		</div>
	</div>
</div>
</html>

<style>
.check-margin {
	margin-left: 12px !important;
}
</style>

<script>
<script>
document.querySelector('#checkbox-user').addEventListener('click', (event) => {
	event.stopImmediatePropagation();
	if (document.querySelector('#checkbox-user').checked)
	{
		for (let input of document.querySelectorAll('input[name="select-user"]'))
		{
			if (!input.checked && !input.disabled)
				input.checked = true;
		}
	}
	else
	{
		for (let input of document.querySelectorAll('input[name="select-user"]'))
		{
			if (input.checked && !input.disabled)
				input.checked = false;
		}
	}
});
document.querySelector('input[name="select-user"]').addEventListener('click', (event) => {
	if (document.querySelector('#checkbox-user').checked)
		document.querySelector('#checkbox-user').checked = false;
});
</script>
</script>