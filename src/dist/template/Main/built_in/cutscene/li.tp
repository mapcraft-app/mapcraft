<html>
<li id="{ID}" name="{Name}" class="uk-flex uk-flex-between">
	<div class="inline-content">
		<h3 class="uk-margin-remove" uk-tooltip="title: {CutsceneHashtag}">
			<span uk-icon="icon: hashtag; ratio: 1.5"></span> {Tag}
		</h3>
		<h3 class="uk-margin-remove">
			<span uk-icon="icon: search; ratio: 1.5"></span> {Name}
		</h3>
		<h3 class="uk-margin-remove">
			<span uk-icon="icon: clock; ratio: 1.5"></span>
			<span time>{Duration}</span>
		</h3>
	</div>
</li>
</html>

<style>
.inline-content {
	display: contents;
}
</style>
