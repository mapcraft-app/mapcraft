<html>
<button id="form-item-modal-{type}-list-close" class="uk-button uk-button-link criteria-close-button">
	<span uk-icon="close"></span>
</button>
<div class="uk-margin">
	<label class="uk-form-label" for="form-item-modal-{type}-list-search" lang="Edit.Criteria.Item.Enchantment"></label>
	<div class="uk-form-controls" id="form-item-modal-{type}-list-search"></div>
</div>
<div class="uk-margin">
	<label class="uk-form-label" for="form-item-modal-{type}-list-level" lang="Edit.Criteria.Item.Levels"></label>
	<div class="uk-form-controls" id="form-item-modal-{type}-list-level">
		<div class="min-max-form">
			<label for="form-item-modal-{type}-list-level-min" lang="Edit.Criteria.Item.Minimum"></label>
			<input class="uk-input uk-form-width-small" id="form-item-modal-{type}-list-level-min" type="number" step="1">
		</div>
		<div class="min-max-form">
			<label for="form-item-modal-{type}-list-level-max" lang="Edit.Criteria.Item.Maximum"></label>
			<input class="uk-input uk-form-width-small" id="form-item-modal-{type}-list-level-max" type="number" step="1">
		</div>
	</div>
</div>
</html>
