<html>
<button id="form-effects-block-close" class="uk-button uk-button-link criteria-close-button">
	<span uk-icon="close"></span>
</button>
<div class="uk-margin">
	<label class="uk-form-label" for="form-effects-block-search" lang="Edit.Criteria.Effects.Effects"></label>
	<div class="uk-form-controls" id="form-effects-block-search"></div>
</div>
<div class="uk-margin">
	<label class="uk-form-label" for="form-effects-block-duration" lang="Edit.Criteria.Effects.Duration"></label>
	<div class="uk-form-controls">
		<input class="uk-input" id="form-effects-block-duration" type="number" min="0" max="1000000">
	</div>
</div>
<div class="uk-margin">
	<label class="uk-form-label" for="form-effects-block-amplifier" lang="Edit.Criteria.Effects.Amplifier"></label>
	<div class="uk-form-controls">
		<input class="uk-input" id="form-effects-block-amplifier" type="number" min="0" max="255">
	</div>
</div>
</html>
