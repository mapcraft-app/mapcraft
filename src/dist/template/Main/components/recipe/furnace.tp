[HTML]
<div class="craft">
	<div id="{ID}" class="craft_background">
		<div id="{ID}-cases" class="recipes_cases_furnace">
			<div class="case"></div>
			<img class="craft_fire_and_cross" src="dist/img/assets/fire.png"/>
			<div class="case"></div>
		</div>
		<img class="craft_arrow" src="dist/img/assets/arrow.png"/>
