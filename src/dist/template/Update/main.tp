<html>
<div id="form" class="uk-container uk-margin-top uk-flex uk-flex-column uk-flex-between body-height">
	<dl class="uk-description-list uk-description-list-divider">
		<dt lang="Software"></dt>
		<dd id="text-software">
			<div uk-spinner></div>
		</dd>
		<div class="uk-animation-fade uk-animation-fast description hidden" target="text-software">
			<p>No changelog</p>
		</div>
		
		<dt lang="Datapack"></dt>
		<dd id="text-datapack">
			<div uk-spinner></div>
		</dd>
		<div class="uk-animation-fade uk-animation-fast description hidden" target="text-datapack">
			<p>No changelog</p>
		</div>
		
		<dt lang="ResourcePack"></dt>
		<dd id="text-resourcepack">
			<div uk-spinner></div>
		</dd>
		<div class="uk-animation-fade uk-animation-fast description hidden" target="text-resourcepack">
			<p>No changelog</p>
		</div>
	</dl>
	<div id="validation-button">
		<h3 id="text-title"></h3>
		<div class="uk-flex uk-flex-around uk-flex-wrap">
			<button id="close-update" class="uk-button uk-button-danger" lang="Later"></button>
			<button id="make-update" class="uk-button uk-button-success" lang="Update"></button>
		</div>
	</div>
</div>
<div id="spinner-update" class="uk-flex uk-flex-middle uk-flex-center" style="height: 100%; display: none; flex-direction: column;">
	<img class="img-work-in-progress" src="dist/img/loader.gif"/>
	<h4 class="uk-text-center" lang="UpdateProgress"></h4>
</div>
</html>

<script>
const list = document.getElementsByTagName('dd');
for (const element of list)
{
	element.addEventListener('click', (event) => 
	{
		event.preventDefault();
		event.stopImmediatePropagation();
		const el = document.querySelector(`[target="${element.getAttribute('id')}"]`).classList.toggle('hidden');
	});
}
</script>

<style>
html {
	height: 100%;
}
body {
	height: 90%;
}
dd {
	cursor: pointer;
}
.body-height {
	height: 100%;
}
.uk-description-list > dt {
    color: rgb(211, 207, 201);
}

#text-title {
	text-align: center;
}
.span-download {
	margin-right: 1em;
    color: goldenrod;
}
.span-check {
	margin-right: 1em;
    color: green;
}
#validation-button {
	display: none;
	padding-bottom: 1em;
}

.description {
	display: block;
	background-color: #27292a;
    padding: 0.3em;
}
.hidden {
	display: none !important;
}
</style>